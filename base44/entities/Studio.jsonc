{
  "name": "Studio",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "timezone": {
      "type": "string",
      "default": "Europe/Berlin"
    },
    "defaultLanguage": {
      "type": "string",
      "default": "de"
    }
  },
  "required": [
